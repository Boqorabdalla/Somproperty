{
    "name": "kingflamez/laravelrave",
    "description": "Laravel package for Flutterwave Rave",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.1 || ^8.2 || ^8.3",
        "illuminate/support": "^10.0 || ^11.0 || ^12.0"
    },
    "autoload": {
        "psr-4": {
            "KingFlamez\\Rave\\": "src/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "KingFlamez\\Rave\\RaveServiceProvider"
            ],
            "aliases": {
                "Rave": "KingFlamez\\Rave\\Facades\\Rave"
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
